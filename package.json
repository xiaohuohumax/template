{
  "name": "node-github-action-template",
  "version": "2.0.0",
  "private": true,
  "description": "node github action template",
  "author": {
    "name": "xiaohuohumax",
    "url": "https://github.com/xiaohuohumax"
  },
  "keywords": [
    "node",
    "action",
    "template",
    "commitizen",
    "changeset"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- node dist/index.js",
    "build": "npm run lint:fix && npm run package",
    "commit": "git add . && cz",
    "package": "npx ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "postinstall": "simple-git-hooks",
    "changeset": "changeset",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.7.3",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.2.2",
    "@commitlint/config-conventional": "^19.2.2",
    "@vercel/ncc": "^0.38.2",
    "commitizen": "^4.3.1",
    "cz-git": "^1.10.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.11.1",
    "simple-git-hooks": "^2.11.1"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit $1"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
