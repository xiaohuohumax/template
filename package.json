{
  "publisher": "xiaohuohumax",
  "name": "node-vscode-extension-template",
  "displayName": "Vscode Extension Template",
  "version": "1.2.0",
  "private": true,
  "description": "vscode extension template",
  "author": {
    "name": "xiaohuohumax",
    "url": "https://github.com/xiaohuohumax"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaohuohumax/template.git"
  },
  "keywords": [
    "node",
    "template",
    "commitizen",
    "changeset"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.87.0"
  },
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "vscode-extension-template.helloWorld",
        "title": "%vscode-extension-template.helloWorld.title%"
      }
    ]
  },
  "scripts": {
    "install:all": "npm install --frozen-lockfile && npm install --prefix=webview/hello --frozen-lockfile",
    "commit": "git add . && cz",
    "postinstall": "simple-git-hooks",
    "changeset": "changeset",
    "release": "npm run build && changeset publish",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build",
    "build": "npm run build:hello && vite build --emptyOutDir",
    "build:hello": "npm run build --prefix=webview/hello",
    "watch": "vite build --watch --mode development --emptyOutDir",
    "watch:hello": "npm run watch --prefix=webview/hello",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "vsce-publish": "vsce publish",
    "vsce-package": "vsce package"
  },
  "dependencies": {
    "jsonc-parser": "^3.2.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.7.3",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.2.2",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "18.x",
    "@types/vscode": "^1.87.0",
    "@vscode/test-web": "^0.0.53",
    "commitizen": "^4.3.0",
    "cz-git": "^1.9.1",
    "eslint": "^9.10.0",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.3.3",
    "vite": "^5.2.10"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit $1"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
