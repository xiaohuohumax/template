{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "#/*": [
        "./*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vite/client",
      "node"
    ],
    "noEmit": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true
  },
  "include": [
    "src",
    "types",
    "webview/types"
  ]
}